bMovesFocus && !suggestWidgetVisible || inlineEditIsVisible && inlineSuggestionHasIndentationLessThanTabSize && inlineSuggestionVisible && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible || inlineEditIsVisible && inlineSuggestionVisible && tabShouldAcceptInlineEdit && !editorHoverFocused && !editorTabMovesFocus && !suggestWidgetVisible\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+enter\\\",\\n        \\\"command\\\": \\\"workbench.action.terminal.sendSequence\\\",\\n        \\\"args\\\": {\\n            \\\"text\\\": \\\"\\\\\\\\\\\\r\\\\n\\\"\\n        },\\n        \\\"when\\\": \\\"terminalFocus\\\"\\n    },\\n    {\\n      \\\"key\\\": \\\"ctrl+l\\\",\\n      \\\"command\\\": \\\"workbench.panel.chat\\\",\\n      \\\"when\\\": \\\"workbench.panel.chat.view.copilot.active\\\"\\n    },\\n    {\\n      \\\"key\\\": \\\"ctrl+alt+i\\\",\\n      \\\"command\\\": \\\"-workbench.panel.chat\\\",\\n      \\\"when\\\": \\\"workbench.panel.chat.view.copilot.active\\\"\\n    },\\n    {\\n      \\\"key\\\": \\\"ctrl+shift+l\\\",\\n      \\\"command\\\": \\\"workbench.action.openChat\\\",\\n      \\\"when\\\": \\\"chatIsEnabled && inChat && inChatEditor\\\"\\n    },\\n    {\\n      \\\"key\\\": \\\"ctrl+n\\\",\\n      \\\"command\\\": \\\"-workbench.action.openChat\\\",\\n      \\\"when\\\": \\\"chatIsEnabled && inChat && inChatEditor\\\"\\n    },\\n    {\\n      \\\"key\\\": \\\"ctrl+shift+l\\\",\\n      \\\"command\\\": \\\"workbench.action.chat.newChat\\\",\\n      \\\"when\\\": \\\"chatIsEnabled && inChat\\\"\\n    },\\n    {\\n      \\\"key\\\": \\\"ctrl+n\\\",\\n      \\\"command\\\": \\\"-workbench.action.chat.newChat\\\",\\n      \\\"when\\\": \\\"chatIsEnabled && inChat\\\"\\n    },\\n    {\\n      \\\"key\\\": \\\"alt+t\\\",\\n      \\\"command\\\": \\\"github.copilot.completions.toggle\\\"\\n    },\\n    {\\n      \\\"key\\\": \\\"ctrl+i\\\",\\n      \\\"command\\\": \\\"-markdown.extension.editing.toggleItalic\\\",\\n      \\\"when\\\":